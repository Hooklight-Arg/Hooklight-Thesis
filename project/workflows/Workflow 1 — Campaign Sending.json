      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO events (user_id, campaign_id, event_type, event_time, ip, user_agent, country)\nSELECT\n  '{{ $(\"Code in JavaScript\").item.json.user_id }}'::uuid,\n  '{{ $(\"Code in JavaScript\").item.json.campaign_id }}',\n  'sent',\n  NOW() AT TIME ZONE 'America/Argentina/Buenos_Aires',\n  '',\n  'n8n-mailgun',\n  ''\nWHERE NOT EXISTS (\n  SELECT 1\n  FROM events\n  WHERE user_id = '{{ $(\"Code in JavaScript\").item.json.user_id }}'::uuid\n    AND campaign_id = '{{ $(\"Code in JavaScript\").item.json.campaign_id }}'\n    AND event_type = 'sent'\n);\n",
        "options": {}
