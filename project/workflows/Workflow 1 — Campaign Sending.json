        "jsCode": "function uuidv4() {\n  return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {\n    const r = Math.random() * 16 | 0;\n    const v = c === 'x' ? r : (r & 0x3 | 0x8);\n    return v.toString(16);\n  });\n}\n\nreturn items.map(item => {\n  return {\n    json: {\n      ...item.json,\n      email: item.json.email || item.json.correo || item.json.mail || '',\n      province: item.json.province || item.json.provincia || '',\n      department: item.json.department || item.json.departamento || '',\n      user_id: item.json.user_id || uuidv4(),\n      campaign_id: item.json.campaign_id || 'camp01'\n    }\n  };\n});\n"
